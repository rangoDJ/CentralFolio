# Your public domain (no https:// prefix — Caddy adds that)
PUBLIC_DOMAIN=folio.example.com

# Required: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=

# Logging: VERBOSE | DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO

# Optional: inject SnapTrade credentials at the host level instead of via the Settings UI
# SNAPTRADE_CLIENT_ID=
# SNAPTRADE_CONSUMER_KEY=
